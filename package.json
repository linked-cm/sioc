{
  "name": "@_linked/sioc",
  "description": "SIOC (Semantically-Interlinked Online Communities) vocabulary as @linkedShape classes — UserAccount, Site, Space, Container, Item, Role, Usergroup. Renamed from lincd-sioc (plan-011).",
  "author": {
    "name": "",
    "email": "",
    "url": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "version": "1.1.0",
  "linkedPackage": true,
  "type": "module",
  "main": "lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "license": "ISC",
  "scripts": {
    "start": "npm exec linked dev",
    "build": "rimraf ./lib && yarn build-esm && yarn copy-to-lib",
    "build-esm": "echo \"compiling ESM\" && rimraf ./lib/esm && yarn tsc -p tsconfig-esm.json",
    "copy-to-lib": "echo 'copying CSS + JSON assets to lib folder' && yarn copyfiles -u 1 'src/**/*.css' 'src/**/*.json' lib/esm"
  },
  "keywords": [
    "linked",
    "linked code",
    "linked data",
    "interoperable",
    "semantic web",
    "sioc",
    "web3"
  ],
  "module": "lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/esm/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/esm/index.js"
    },
    "./*.js": {
      "types": "./lib/esm/*.d.ts",
      "development": "./src/*.ts",
      "import": "./lib/esm/*.js"
    },
    "./*": {
      "types": "./lib/esm/*.d.ts",
      "development": "./src/*.ts",
      "import": "./lib/esm/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "lib/esm/*"
      ]
    }
  },
  "dependencies": {
    "@_linked/core": "*",
    "@_linked/dcmi": "*",
    "@_linked/react": "*",
    "@_linked/schema": "*",
    "@_linked/xsd": "*"
  },
  "devDependencies": {
    "@_linked/cli": "^1.2",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.13.14",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.7",
    "tsconfig-to-dual-package": "^1.2.0",
    "typescript": "5.7.3",
    "typescript-plugin-css-modules": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
